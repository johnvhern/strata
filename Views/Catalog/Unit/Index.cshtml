@using Strata.Helpers
@model PaginatedList<Strata.Models.Catalog.UnitOfMeasure>
@{
    ViewData["Title"] = "Units";
    var prevDisabled = !Model.HasPreviousPage ? "disabled" : "";
    var nextDisabled = !Model.HasNextPage ? "disabled" : "";
    var startItem = ((Model.PageIndex - 1) * Model.PageSize) + 1;
    var endItem = startItem + Model.Count - 1;
    
    var currentSort = ViewData["CurrentSort"]?.ToString();

    string SortIcon(string ascValue, string descValue, bool isDefaultAsc = false)
    {
        if (isDefaultAsc && string.IsNullOrEmpty(currentSort)) return "▲";
        if (currentSort == ascValue) return "▲";
        if (currentSort == descValue) return "▼";
        return "";
    }
}

<div class="d-flex justify-content-between mb-3">
    <h3 class="fw-bold">Units</h3>
    <button type="button" class="btn btn-primary d-flex align-items-center gap-1 js-unit-create" data-bs-toggle="ajax-modal" data-url="@Url.Action("Create", "Unit")">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
             class="lucide lucide-plus-icon lucide-plus">
            <path d="M5 12h14" />
            <path d="M12 5v14" />
        </svg>
        <span>Create</span>
    </button>
</div>

<form asp-action="Index" method="get" class="row g-2 mb-3">
    <div class="col-12 col-md-3">
        <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" class="form-control"
               placeholder="Search unit" />
    </div>
    <div class="col-12 col-md-1 d-grid">
        <button type="submit" class="btn btn-primary">Search</button>
    </div>
</form>

<div id="modal-placeholder"></div>

<div class="card mb-3">
    <div class="card-body table-responsive-sm">
        <table class="table table-hover table-sm align-middle">
            <thead>
                <tr>
                    <th scope="col">
                        <a asp-action="Index"
                           asp-route-sortOrder="@ViewData["NameSort"]"
                           asp-route-searchString="@ViewData["CurrentFilter"]"
                           asp-route-pageNumber="@Model.PageIndex"
                           class="nav-link">
                            <span>Name</span>
                            <span class="sort-icon ms-1">@SortIcon("", "name_desc", true)</span>
                        </a>
                    </th>
                    <th scope="col">Abbreviation</th>
                    <th scope="col">
                        <a asp-action="Index"
                           asp-route-sortOrder="@ViewData["CreatedSort"]"
                           asp-route-searchString="@ViewData["CurrentFilter"]"
                           asp-route-pageNumber="@Model.PageIndex"
                           class="nav-link">
                            <span>Created At</span>
                            <span class="sort-icon ms-1">@SortIcon("CreatedAt", "created_desc", false)</span>
                        </a>
                    </th>
                    <th scope="col">Created By</th>
                    <th scope="col">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var unit in Model)
                {
                    <tr>
                        <td>@unit.Name</td>
                        <td>@unit.Abbreviation</td>
                        <td>@unit.CreatedAt.ToString("MM/dd/yyyy")</td>
                        <td>@unit.CreatedBy</td>
                        <td>
                            <button class="btn btn-secondary btn-sm js-unit-edit" data-bs-toggle="ajax-modal" data-url="@Url.Action("Edit", "Unit", new { id = unit.Id })">Edit</button>
                            <button class="btn btn-danger btn-sm js-unit-delete" data-bs-toggle="ajax-modal" data-url="@Url.Action("Delete", "Unit", new { id = unit.Id })">Delete</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="align-items-center justify-content-between d-sm-block d-lg-flex">
    @if (Model.TotalCount == 0)
    {
        <p class="text-muted mb-2 small">
            Showing 0 entries
        </p>
    }
    else
    {
        <p class="text-muted mb-2 small">
            Showing @startItem to @endItem of @Model.TotalCount entries
        </p>
    }

    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Unit pagination">
            <ul class="pagination pagination-sm justify-content-center">
                <li class="page-item @prevDisabled">
                    <a class="page-link" asp-action="Index" asp-route-pageNumber="@(Model.PageIndex - 1)"
                       asp-route-searchString="@ViewData["CurrentFilter"]">Previous</a>
                </li>

                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-pageNumber="@i"
                           asp-route-searchString="@ViewData["CurrentFilter"]">@i</a>
                    </li>
                }

                <li class="page-item @nextDisabled">
                    <a class="page-link" asp-action="Index" asp-route-pageNumber="@(Model.PageIndex + 1)"
                       asp-route-searchString="@ViewData["CurrentFilter"]">Next</a>
                </li>
            </ul>
        </nav>
    }
</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />

    <script>
        $(function () {
            AppUI.showToastFromQuery('created', 'Successfully created unit!', 'success');
            AppUI.showToastFromQuery('updated', 'Unit successfully updated!', 'info');
            AppUI.showToastFromQuery('deleted', 'Unit successfully deleted!', 'warning');

            AppUI.initAjaxModal({
                triggerSelector: '.js-unit-create',
                placeholderSelector: '#modal-placeholder',
                modalSelector: '#createModal',
                formSelector: '#unitCreateForm',
                saveButtonSelector: '.js-save-create-unit',
                successRedirectUrl: '@Url.Action("Index", "Unit")',
                successQueryKey: 'created',
                errorMessage: 'Error creating unit!'
            });

            AppUI.initAjaxModal({
                triggerSelector: '.js-unit-edit',
                placeholderSelector: '#modal-placeholder',
                modalSelector: '#editModal',
                formSelector: '#unitEditForm',
                saveButtonSelector: '.js-save-edit-unit',
                successRedirectUrl: '@Url.Action("Index", "Unit")',
                successQueryKey: 'updated',
                errorMessage: 'Error updating unit!'
            });
            
            AppUI.initAjaxModal({
                triggerSelector: '.js-unit-delete',
                placeholderSelector: '#modal-placeholder',
                modalSelector: '#deleteModal',
                formSelector: '#unitDeleteForm',
                saveButtonSelector: '.js-save-delete-unit',
                successRedirectUrl: '@Url.Action("Index", "Unit")',
                successQueryKey: 'deleted',
                errorMessage: 'Error deleting unit!'
            });
        });
    </script>
}
