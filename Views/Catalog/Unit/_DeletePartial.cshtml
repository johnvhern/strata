@model Strata.ViewModel.Catalog.UnitOfMeasure.UnitDeleteViewModel

<!-- Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModal" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content text-bg-danger">
            <div class="modal-header border-0">
                <h1 class="modal-title fs-5" id="exampleModalLabel">Delete Unit</h1>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete this unit?</p>
                <h5>@Model.Name</h5>
                <form asp-controller="Unit" asp-action="Delete" method="post" id="unitDeleteForm">
                    <input type="hidden" asp-for="Id"/>
                    <input type="hidden" name="IsValid" value="@ViewData.ModelState.IsValid.ToString()"/>
                </form>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-danger js-save-delete-unit">Confirm</button>
            </div>
        </div>
    </div>
</div>