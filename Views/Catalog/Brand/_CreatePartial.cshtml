@model Strata.ViewModel.Catalog.Brand.BrandCreateViewModel

<!-- Modal -->
<div class="modal fade" id="createModal" tabindex="-1" aria-labelledby="createModal" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-0 pb-0">
                <div>
                    <div class="text-muted small text-uppercase fw-semibold">Catalog</div>
                    <h1 class="modal-title fs-4 fw-bold mb-1" id="createModalLabel">Create Brand</h1>
                    <p class="text-muted small mb-0">Add a new catalog brand with its details.</p>
                </div>
                <button type="button" class="btn-close align-self-baseline" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body pt-3">
                <div class="card border-0 bg-light-subtle">
                    <div class="card-body">
                        <form asp-controller="Brand" asp-action="Create" method="post" id="brandCreateForm">
                            <div class="mb-3">
                                <label asp-for="Name" class="form-label">Name</label>
                                <input asp-for="Name" class="form-control" placeholder="Epson" />
                                <span asp-validation-for="Name" class="text-danger small"></span>
                            </div>
                            <input type="hidden" name="IsValid" value="@ViewData.ModelState.IsValid.ToString()"/>
                        </form>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-primary js-save-create-brand">Save Brand</button>
            </div>  
        </div>
    </div>
</div>

