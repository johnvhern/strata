@using Strata.Helpers
@model PaginatedList<Strata.Models.Catalog.Category>
@{
    ViewData["Title"] = "Categories";
    var prevDisabled = !Model.HasPreviousPage ? "disabled" : "";
    var nextDisabled = !Model.HasNextPage ? "disabled" : "";
    var startItem = ((Model.PageIndex - 1) * Model.PageSize) + 1;
    var endItem = startItem + Model.Count - 1;
}

<div class="d-flex justify-content-between mb-3">
    <h3 class="fw-bold">Categories</h3>
    <button type="button" class="btn btn-primary d-flex align-items-center gap-1 js-category-create" data-bs-toggle="ajax-modal" data-url="@Url.Action("Create", "Category")">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
             class="lucide lucide-plus-icon lucide-plus">
            <path d="M5 12h14" />
            <path d="M12 5v14" />
        </svg>
        <span>Create</span>
    </button>
</div>

<form asp-action="Index" method="get" class="row g-2 mb-3">
    <div class="col-12 col-md-5">
        <input type="text"
               name="searchString"
               value="@ViewData["CurrentFilter"]"
               class="form-control"
               placeholder="Search category" />
    </div>
    <div class="col-12 col-md-1 d-grid">
        <button type="submit" class="btn btn-primary">Search</button>
    </div>
</form>

<div id="modal-placeholder"></div>

<div class="card mb-3">
    <div class="card-body table-responsive">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th scope="col">Name</th>
                    <th scope="col">Description</th>
                    <th scope="col">Created At</th>
                    <th scope="col">Created By</th>
                    <th scope="col">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var category in Model)
                {
                    <tr>
                        <td class="align-content-center">@category.Name</td>
                        <td class="align-content-center">@category.Description</td>
                        <td class="align-content-center">@category.CreatedAt.ToString("MM/dd/yyyy")</td>
                        <td class="align-content-center">@category.CreatedBy</td>
                        <td>
                            <button class="btn btn-secondary btn-sm js-category-edit" data-bs-toggle="ajax-modal" data-url="@Url.Action("Edit", "Category", new { id = category.Id })">Edit</button>
                            <button class="btn btn-danger btn-sm js-category-delete" data-bs-toggle="ajax-modal" data-url="@Url.Action("Delete", "Category", new { id = category.Id })">Delete</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="align-items-center justify-content-between d-sm-block d-lg-flex">
    @if (Model.TotalCount == 0)
    {
        <p class="text-muted mb-2 small">
            Showing 0 entries
        </p>
    }
    else
    {
        <p class="text-muted mb-2 small">
            Showing @startItem to @endItem of @Model.TotalCount entries
        </p>
    }

    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Category pagination">
            <ul class="pagination pagination-sm justify-content-center">
                <li class="page-item @prevDisabled">
                    <a class="page-link" asp-action="Index" asp-route-pageNumber="@(Model.PageIndex - 1)"
                       asp-route-searchString="@ViewData["CurrentFilter"]">Previous</a>
                </li>

                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-pageNumber="@i"
                           asp-route-searchString="@ViewData["CurrentFilter"]">@i</a>
                    </li>
                }

                <li class="page-item @nextDisabled">
                    <a class="page-link" asp-action="Index" asp-route-pageNumber="@(Model.PageIndex + 1)"
                       asp-route-searchString="@ViewData["CurrentFilter"]">Next</a>
                </li>
            </ul>
        </nav>
    }
</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />

    <script>
        $(function () {
            AppUI.showToastFromQuery('created', 'Successfully created category!', 'success');
            AppUI.showToastFromQuery('updated', 'Category successfully updated!', 'info');
            AppUI.showToastFromQuery('deleted', 'Category successfully deleted!', 'warning');

            AppUI.initAjaxModal({
                triggerSelector: '.js-category-create',
                placeholderSelector: '#modal-placeholder',
                modalSelector: '#createModal',
                formSelector: '#categoryCreateForm',
                saveButtonSelector: '.js-save-create-category',
                successRedirectUrl: '@Url.Action("Index", "Category")',
                successQueryKey: 'created',
                errorMessage: 'Error creating category!'
            });

            AppUI.initAjaxModal({
                triggerSelector: '.js-category-edit',
                placeholderSelector: '#modal-placeholder',
                modalSelector: '#editModal',
                formSelector: '#categoryEditForm',
                saveButtonSelector: '.js-save-edit-category',
                successRedirectUrl: '@Url.Action("Index", "Category")',
                successQueryKey: 'updated',
                errorMessage: 'Error updating category!'
            });
            
            AppUI.initAjaxModal({
                triggerSelector: '.js-category-delete',
                placeholderSelector: '#modal-placeholder',
                modalSelector: '#deleteModal',
                formSelector: '#categoryDeleteForm',
                saveButtonSelector: '.js-save-delete-category',
                successRedirectUrl: '@Url.Action("Index", "Category")',
                successQueryKey: 'deleted',
                errorMessage: 'Error deleting category!'
            });
        });
    </script>
}