@model Strata.ViewModel.Catalog.Category.CategoryEditViewModel

<!-- Modal -->
<div class="modal fade" id="editModal" tabindex="-1" aria-labelledby="editModal" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h1 class="modal-title fs-5" id="exampleModalLabel">Edit Brand</h1>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form asp-controller="Category" asp-action="Edit" method="post" id="categoryEditForm">
                    <input type="hidden" asp-for="Id"/>
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label">Name</label>
                        <input asp-for="Name" class="form-control" placeholder="Epson"/>
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">Description</label>
                        <textarea asp-for="Description" class="form-control" placeholder="Epson" rows="3"></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>
                    <input type="hidden" name="IsValid" value="@ViewData.ModelState.IsValid.ToString()"/>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-primary js-save-edit-category">Save</button>
            </div>
        </div>
    </div>
</div>